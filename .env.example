# --- Docker Compose：PostgreSQL ---
POSTGRES_USER=appstore
POSTGRES_PASSWORD=appstore
POSTGRES_DB=appstore

# --- Docker Compose：MinIO ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=app-store

# --- Docker Compose：OpenSearch ---
OPENSEARCH_JAVA_OPTS=-Xms512m -Xmx512m

# --- ClamAV ---
CLAMAV_HOST=clamav
CLAMAV_PORT=3310

# --- 通义千问（本地勿提交真实 KEY；Docker 传入 build args / env）---
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=
QWEN_MODEL=qwen-turbo

# --- 后端（容器内需指向服务名 postgres / minio / opensearch / clamav）---
DATABASE_URL=postgresql+asyncpg://appstore:appstore@postgres:5432/appstore
DEBUG=false
JWT_SECRET_KEY=change-me-in-production

MINIO_ENDPOINT_URL=http://minio:9000
OPENSEARCH_HOST=opensearch
OPENSEARCH_PORT=9200

# 本地开发（不经过 Docker 时改为 localhost）
# DATABASE_URL=postgresql+asyncpg://appstore:appstore@localhost:5432/appstore
# MINIO_ENDPOINT_URL=http://localhost:9000
# OPENSEARCH_HOST=localhost
# CLAMAV_HOST=localhost

# --- MinIO 外部地址（局域网/公网客户端下载用）---
MINIO_EXTERNAL_URL=http://localhost:9000

# --- SMTP 邮件（注册验证码，待配置）---
# SMTP_HOST=smtp.exmail.qq.com
# SMTP_PORT=465
# SMTP_USER=noreply@yourdomain.com
# SMTP_PASSWORD=your-smtp-password
# SMTP_FROM_NAME=JSD SkillHub
